# Dépendances
node_modules/

# Identifiants de session WhatsApp (Baileys) — NE JAMAIS committer
auth/
auth-*/

# Contenu privé des messages (archives JSONL) — NE JAMAIS committer
data/
data-*/

# Variables d'environnement / secrets
.env
.env.*
!.env.example

# Canaux autorisés : contient les JID/noms de tes groupes -> privé
settings.json
settings-*.json

# Le plafond (ADR-0002) : mêmes données privées -> jamais commité
allowlist.json
allowlist-*.json

# Drapeau d'authentification forte (ADR-0003) : désarmement manuel local -> jamais commité
strong-auth.json
strong-auth-*.json

# Logs
*.log

# Divers OS / éditeurs
.DS_Store

# Note de handoff ezk-archive : éphémère personnel, jamais committé
.claude/handoff.md

# Scratch de sprint ezk-sprint : éphémère par-branche, jamais committé
SPRINT.md

# Secrets/variables pour act (CI en local) — jamais committés.
# Aucun workflow n'en utilise aujourd'hui ; la règle est posée d'avance.
.secrets
.vars
